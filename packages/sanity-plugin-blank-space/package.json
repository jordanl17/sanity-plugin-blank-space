{
  "name": "sanity-plugin-blank-space",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "A Sanity Studio plugin for adding blank space between fields",
  "keywords": [
    "sanity",
    "sanity-plugin"
  ],
  "homepage": "https://github.com/jordanl17/sanity-plugin-blank-space#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordanl17/sanity-plugin-blank-space.git",
    "directory": "packages/sanity-plugin-blank-space"
  },
  "bugs": {
    "url": "https://github.com/jordanl17/sanity-plugin-blank-space/issues"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "browserslist": "extends @sanity/browserslist-config",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "pkg-utils build --strict --check --clean",
    "clean": "rimraf dist",
    "link-watch": "pkg-utils watch --tsconfig tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "yalc:publish": "npx yalc publish"
  },
  "peerDependencies": {
    "@sanity/icons": "^3.0.0",
    "@sanity/ui": "^2.0.0 || ^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "sanity": "^3.0.0 || ^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@sanity/icons": "^3.7.4",
    "@sanity/pkg-utils": "^10.4.6",
    "@sanity/plugin-kit": "^4.0.20",
    "@sanity/ui": "^3.1.13",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  }
}
